<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.GestionEventos" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/app_primary</item>
        <item name="colorPrimaryDark">@color/app_primary_dark</item>
        <item name="colorSecondary">@color/app_secondary</item>
        <item name="colorAccent">@color/app_secondary</item>
        <item name="colorError">@color/app_danger</item>
        <item name="android:colorAccent">@color/app_secondary</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:statusBarColor">@color/app_primary</item>
        <item name="android:fontFamily">sans</item>
        <item name="materialButtonStyle">@style/Widget.GestionEventos.Button</item>
        <item name="floatingActionButtonStyle">@style/Widget.GestionEventos.Fab</item>
    </style>

    <style name="Theme.GestionEventos" parent="Base.Theme.GestionEventos" />

    <style name="Widget.GestionEventos.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/app_primary</item>
        <item name="android:textColor">@color/app_on_primary</item>
        <item name="iconTint">@color/app_on_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.GestionEventos.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/app_primary</item>
        <item name="android:textColor">@color/app_primary</item>
        <item name="iconTint">@color/app_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.GestionEventos.Fab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/app_secondary</item>
        <item name="tint">@color/app_on_primary</item>
    </style>
</resources>
